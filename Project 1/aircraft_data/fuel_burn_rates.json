{
  "_metadata": {
    "description": "Cruise-phase fuel burn rates for United Airlines fleet variants",
    "units": "US gallons per hour (gph) at typical cruise conditions (FL350-390, ISA, MTOW-10%)",
    "methodology": "Engine TSFC × cruise thrust × 2 engines ÷ 6.7 lb/gal. Cross-validated against BTS Form 41 P-12(a) reported gallons ÷ block hours.",
    "notes": [
      "Cruise TSFC sourced from FAA Type Certificate Data Sheets (TCDS) and Jane's Aero-Engines.",
      "Cruise thrust estimated at 20-25% of sea-level rated thrust (typical cruise condition).",
      "BTS block-hour figures include taxi, climb, and descent — slightly higher than pure cruise; use 'bts_block_hour_gph' for cost matching, 'poh_cruise_gph' for range calculations.",
      "737 MAX variants: ~16% fuel burn improvement over corresponding NG type per Boeing Performance Disclosure.",
      "787 variants: ~20-25% improvement over 767 equivalents per Boeing / GE press releases."
    ],
    "sources": [
      "FAA TCDS E6NE (CFM56-7B series)",
      "FAA TCDS E34NE (LEAP-1B series)",
      "FAA TCDS E29NE (GE90-100 series)",
      "FAA TCDS E26NE (GEnx-1B series)",
      "FAA TCDS E22NE (CF34-8C series)",
      "Jane's Aero-Engines, Issue 30",
      "BTS Form 41 P-12(a) — United Airlines 2019-2023 actuals",
      "Boeing 737 NG / MAX FCOM fuel planning charts",
      "Boeing 777 FCOM Section 11",
      "Boeing 787 FCOM Section 11",
      "Embraer E-Jet Family Airport Planning document"
    ],
    "last_updated": "2026-06"
  },

